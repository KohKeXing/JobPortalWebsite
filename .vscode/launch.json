{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Flask (Auto-Open Browser)",
            "type": "debugpy",
            "request": "launch",
            "module": "flask",
            "env": {
                "FLASK_APP": "resumeManagement.py",
                "FLASK_DEBUG": "1"
            },
            "args": [
                "run",
                "--no-debugger",
                "--no-reload"
            ],
            "jinja": true,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Running on (http://\\S+)",
                "uriFormat": "%s"
            }
        }
    ]
}